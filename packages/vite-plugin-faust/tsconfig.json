{
  "compilerOptions": {
    "target": "ESNext",
    "strict": true,
    "noFallthroughCasesInSwitch": true,
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noImplicitOverride": true,
    "types": [],
    "outDir": "./dist",
    "declaration": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["FaustLoader.ts", "vitePluginFaust.ts", "test.ts"],
  "exclude": ["packages"]
}

{
  "name": "vite-plugin-monorepo-site",
  "version": "0.1.0",
  "description": "Vite plugin to generate a static site from monorepo package directories",
  "author": "Kevin Chavez",
  "homepage": "https://aykev.dev/pkg/vite-plugin-monorepo-site",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/npm/cli.git",
    "directory": "packages/vite-plugin-monorepo-site"
  },
  "license": "MIT",
  "files": [
    "dist"
  ],
  "keywords": [
    "vite",
    "vite-plugin",
    "markdown",
    "monorepo",
    "static-site"
  ],
  "type": "module",
  "main": "./dist/vitePluginMonorepoSite.js",
  "types": "./dist/vitePluginMonorepoSite.d.ts",
  "exports": {
    ".": {
      "types": "./dist/vitePluginMonorepoSite.d.ts",
      "import": "./dist/vitePluginMonorepoSite.js"
    }
  },
  "scripts": {
    "dev": "npm run build -- --watch",
    "build": "tsup vitePluginMonorepoSite.ts --dts --format esm"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.0.0",
    "tsup": "^8.5.1",
    "vite": "^8.0.4"
  },
  "peerDependencies": {
    "vite": ">=2.6.0"
  },
  "dependencies": {
    "@rollup/pluginutils": "^5.3.0",
    "front-matter": "^4.0.2",
    "markdown-it": "^14.1.1",
    "shiki": "^4.0.2",
    "tinyglobby": "^0.2.0"
  }
}
